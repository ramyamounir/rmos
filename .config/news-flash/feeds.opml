  <body>
    <outline title="News (India)" text="News (India)">
      <outline title="Star of Mysore" text="Star of Mysore" type="rss" xmlUrl="https://starofmysore.com/feed/" htmlUrl="https://starofmysore.com/feed/" />
      <outline title="The Times of India" text="The Times of India" type="rss" xmlUrl="http://timesofindia.indiatimes.com/rssfeeds/1221656.cms" htmlUrl="https://timesofindia.indiatimes.coms/" />
      <outline title="The Hindu" text="The Hindu" type="rss" xmlUrl="http://www.thehindu.com/?service=rss" htmlUrl="https://www.thehindu.com/feeder/default.rss" />
    </outline>
    <outline title="News (US)" text="News (US)">
      <outline title="New York Times" text="New York Times" type="rss" xmlUrl="http://www.nytimes.com/services/xml/rss/nyt/HomePage.xml" htmlUrl="https://www.nytimes.com/" />
    </outline>
    <outline title="News (World)" text="News (World)">
      <outline title="BBC World News" text="BBC World News" type="rss" xmlUrl="http://feeds.bbci.co.uk/news/world/rss.xml" htmlUrl="https://www.bbc.co.uk/news/" />
      <outline title="Reuters News Agency" text="Reuters News Agency" type="rss" xmlUrl="https://www.reutersagency.com/feed/?taxonomy=best-topics&amp;post_type=best" htmlUrl="https://www.reutersagency.com/feed/?taxonomy=best-topics&amp;post_type=best" />
    </outline>
    <outline title="AI/ML maganizes" text="AI/ML maganizes" >
      <outline title="BAIR" text="BAIR" type="rss" xmlUrl="https://bair.berkeley.edu/blog/feed.xml" htmlUrl="http://bair.berkeley.edu/blog/" />
      <outline title="DeepMind" text="DeepMind" type="rss" xmlUrl="https://deepmind.com/blog/feed/basic/" htmlUrl="https://www.deepmind.com/" />
      <outline title="Google AI" text="Google AI" type="rss" xmlUrl="https://blog.google/technology/ai/rss/" htmlUrl="https://blog.google/technology/ai/" />
      <outline title="IEEE Spectrum" text="IEEE Spectrum" type="rss" xmlUrl="http://feeds2.feedburner.com/IeeeSpectrum" htmlUrl="https://spectrum.ieee.org/" />
      <outline title="Microsoft" text="Microsoft" type="rss" xmlUrl="https://docs.microsoft.com/en-us/archive/blogs/machinelearning/feed.xml" htmlUrl="https://docs.microsoft.com/archive/blogs/machinelearning/feed.xml" />
      <outline title="Nature" text="Nature" type="rss" xmlUrl="https://www.nature.com/subjects/machine-learning.rss" htmlUrl="https://www.nature.com/subjects/machine-learning" />
      <outline title="Wired" text="Wired" type="rss" xmlUrl="https://www.wired.com/feed/tag/ai/latest/rss" htmlUrl="https://www.wired.com/" />
      <outline title="Science Daily" text="Science Daily" type="rss" xmlUrl="https://www.sciencedaily.com/rss/computers_math/artificial_intelligence.xml" htmlUrl="https://www.sciencedaily.com/news/computers_math/artificial_intelligence/" />
    </outline>
  </body>
